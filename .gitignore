__pycache__/
.claude/

# Secrets — never commit real environment files or keys (only *.example).
# Backstop for the whole monorepo; subprojects may add stricter rules.
.env
.env.*
!.env.example
!.env.*.example
!*.env.example
*.pem
*.key
*.pfx
*.p12
*.keystore
secrets.*
*credentials*.json
id_rsa
id_ed25519

# Terraform — never commit state, provider caches, real tfvars, or backend config.
# Only *.example files are tracked (see platform/audit-sink, platform/bootstrap).
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
!*.tfvars.example
backend.hcl
!backend.hcl.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
tfplan
*.tfplan

# C++ compiled binaries
cpp/bin/
cpp/build/
cpp/entropy-scanner/entropy-scanner
cpp/cui-classifier/cui-classifier
cpp/yara-lite/yara-lite
cpp/packet-analyzer/packet-analyzer
cpp/arinc429/arinc429-decoder
cpp/mil-std-1553/mil1553-sim
cpp/gps-antispoofing/gps-detector
cpp/rf-anomaly/rf-anomaly
cpp/aes-vault/aes-vault
cpp/zt-policy-engine/zt-policy
cpp/log-correlator/log-correlator
cpp/memory-scanner/memory-scanner
