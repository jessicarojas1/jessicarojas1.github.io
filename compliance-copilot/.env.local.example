# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for AI assistant)
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- AI provider / model selection ---------------------------------------
# Which upstream the AI relay (POST /api/ai/generate) talks to:
#   anthropic  → hosted Anthropic Claude API (default)
#   ollama     → self-hosted Ollama endpoint (air-gapped / CUI — no egress)
AI_PROVIDER=anthropic
# Anthropic model id used when AI_PROVIDER=anthropic. Kept configurable so the
# model can be updated without a code change. Defaults to claude-opus-4-6.
AI_MODEL=claude-opus-4-6
# Self-hosted inference (only used when AI_PROVIDER=ollama). No API key needed —
# the endpoint itself is the trust boundary. See deployments/AIRGAPPED.md.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Shared secret that gates the AI relay (POST /api/ai/generate) for PROGRAMMATIC
# / external callers. They present it as `Authorization: Bearer <token>` or
# `x-api-key: <token>`. The IN-APP browser assistant does NOT use this — it
# authenticates with the session cookie (see APP_SESSION_SECRET below) and the
# relay injects the upstream key server-side, so this token never reaches the
# browser. REQUIRED in production for the relay to accept token-based callers:
# if this is unset while NODE_ENV=production AND there is no valid session, the
# relay fails closed (503) so the server's ANTHROPIC_API_KEY is never exposed as
# an open, unauthenticated AI proxy (OWASP LLM10 / CWE-770). Optional in dev.
AI_PROXY_TOKEN=

# --- In-app session login -------------------------------------------------
# These power the lightweight cookie-based session used by the in-app AI
# assistant so the browser can use the gated AI relay WITHOUT ever holding
# AI_PROXY_TOKEN. Set all three to enable login + route-level session auth.
#
# Secret used to HMAC-sign session cookies. Use a long random value
# (e.g. `openssl rand -base64 48`). MUST be >= 16 chars or sessions are disabled.
APP_SESSION_SECRET=
# Single-tenant login credentials, checked server-side with a constant-time
# comparison. Never commit real values.
APP_AUTH_USERNAME=
APP_AUTH_PASSWORD=

# Optional: Supabase Storage bucket name for evidence files. This bucket MUST be
# created PRIVATE (not public). Evidence is uploaded server-side via the service
# role (POST /api/evidence/upload) and read back only through short-lived signed
# URLs — never a public object URL. See docs/SECURITY.md.
NEXT_PUBLIC_EVIDENCE_BUCKET=evidence-files

# Optional: structured-logging verbosity for API routes (debug|info|warn|error).
# Defaults to info in production, debug otherwise. Logs are JSON lines with a
# per-request req_id — never log secrets or prompt/response bodies.
LOG_LEVEL=

# Optional: protects the shared branding write (PUT /api/settings/branding).
# When set, saving org-wide branding requires this token (entered in
# Settings → Branding → Admin token). Leave unset for single-user / local use.
BRANDING_ADMIN_TOKEN=
