# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for AI assistant)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Shared secret that gates the AI relay (POST /api/ai/generate). Callers must
# present it as `Authorization: Bearer <token>` or `x-api-key: <token>`.
# REQUIRED in production: if this is unset while NODE_ENV=production, the relay
# fails closed (503) so the server's ANTHROPIC_API_KEY is never exposed as an
# open, unauthenticated AI proxy (OWASP LLM10 / CWE-770). Optional in local dev.
AI_PROXY_TOKEN=

# Optional: Supabase Storage bucket name for evidence files
NEXT_PUBLIC_EVIDENCE_BUCKET=evidence-files

# Optional: protects the shared branding write (PUT /api/settings/branding).
# When set, saving org-wide branding requires this token (entered in
# Settings → Branding → Admin token). Leave unset for single-user / local use.
BRANDING_ADMIN_TOKEN=
