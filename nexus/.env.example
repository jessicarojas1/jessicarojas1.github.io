# Copy to .env for local development (never commit .env)

DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus
JWT_SECRET=change-me-to-a-long-random-string
APP_ENV=development

# Set to 1 to accept the well-known seed PINs (rojas/654321, smith/112233, brown/999999).
# Disable in production after running scripts/hash-pins.php.
NEXUS_ALLOW_DEFAULT_PINS=1
