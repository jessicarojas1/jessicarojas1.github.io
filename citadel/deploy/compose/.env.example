# =============================================================================
# CITADEL — production compose stack environment template
# -----------------------------------------------------------------------------
# Copy to `.env` and replace EVERY placeholder with a real value:
#
#     cp .env.example .env
#
# The `.env` file is GIT-IGNORED and MUST NEVER be committed. This template
# contains placeholders ONLY — no real secrets.
#
# Generate strong secrets (do NOT reuse the examples below):
#     openssl rand -base64 48      # for CITADEL_JWT_SECRET / tokens
#     openssl rand -base64 24      # for POSTGRES_PASSWORD / admin password
# =============================================================================

# -----------------------------------------------------------------------------
# Image selection (only used if you switch the compose file to OPTION B image:)
# Pin a tag or, better, a digest (…@sha256:…) for reproducible deploys.
# -----------------------------------------------------------------------------
IMAGE_REF=ghcr.io/your-org/citadel-server:latest

# -----------------------------------------------------------------------------
# Core application runtime (non-secret; sensible defaults baked into compose)
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=8080

# -----------------------------------------------------------------------------
# PostgreSQL — used by BOTH the postgres service (to provision the role/db) and
# the citadel service (to build DATABASE_URL). Keep these in sync.
#   POSTGRES_PASSWORD is REQUIRED — the stack refuses to start without it.
# -----------------------------------------------------------------------------
POSTGRES_USER=citadel
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=citadel

# DATABASE_URL is composed automatically in docker-compose.yml from the three
# vars above and points at the internal `postgres` service. Override here only
# if you point CITADEL at an EXTERNAL/managed database instead of the bundled one:
# DATABASE_URL=postgres://user:password@db.example.internal:5432/citadel?sslmode=require

# TLS to the database.
#   In-stack Postgres on the private `backend` network => PGSSL=0 / disable.
#   Managed/remote Postgres => PGSSL=1 and PGSSLMODE=require (mount certs as needed).
PGSSL=0
# sslmode used when composing DATABASE_URL: disable | require | verify-full
PGSSLMODE=disable

# -----------------------------------------------------------------------------
# Authentication / admin bootstrap & service tokens (SECRETS — rotate these!)
# -----------------------------------------------------------------------------
# Signs/verifies session JWTs. MUST be long & random. Rotating invalidates sessions.
CITADEL_JWT_SECRET=CHANGE_ME_openssl_rand_base64_48

# Initial administrator account created on first boot.
CITADEL_ADMIN_EMAIL=admin@example.com
CITADEL_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Privileged out-of-band tokens. Treat as secrets; rotate on exposure.
#   SUPERADMIN_TOKEN -> cross-tenant superadmin API (only meaningful w/ multitenancy)
#   METRICS_TOKEN    -> bearer token guarding the /metrics endpoint
CITADEL_SUPERADMIN_TOKEN=CHANGE_ME_openssl_rand_base64_48
CITADEL_METRICS_TOKEN=CHANGE_ME_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Multi-tenancy (OFF by default). Set to 1 to enable tenant sub-domain routing,
# then point CITADEL_BASE_DOMAIN at the apex you serve tenants under, e.g.
# tenant "acme" => acme.citadel.example.com. See README "Enabling multi-tenancy".
# -----------------------------------------------------------------------------
CITADEL_MULTITENANT=0
CITADEL_BASE_DOMAIN=citadel.example.com
