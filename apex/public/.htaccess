Options -MultiViews -Indexes
RewriteEngine On

# Force HTTPS (trust X-Forwarded-Proto from reverse proxy / Render / Heroku).
# §8/H10: prevents cleartext transmission of CAC/PIN auth traffic.
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Static security headers. CSP is set here (this is a static SPA shell with no
# per-request PHP nonce); 'unsafe-inline' is required for style-src because the
# shell uses inline style= attributes and apex.js sets styles dynamically.
# script-src stays strict ('self') — the shell loads only /app/apex.js, no inline
# or third-party JS. Bootstrap is loaded as CSS only, from jsdelivr.
# NOTE: the deprecated X-XSS-Protection header is intentionally omitted; modern
# guidance (OWASP/CISA) is to rely on the CSP below instead.
<IfModule mod_headers.c>
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; font-src 'self' https://cdn.jsdelivr.net; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always unset X-Powered-By
</IfModule>

# Let real files and directories pass through unchanged
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route all /api/* requests through the API dispatcher
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Everything else -> SPA shell
RewriteRule ^ index.php [L]
