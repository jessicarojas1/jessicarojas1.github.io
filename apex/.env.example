# Copy to .env for local development (never commit .env)

DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus
JWT_SECRET=change-me-to-a-long-random-string
APP_ENV=development

# Set to 1 (NON-production only) to accept the well-known seed PINs
# (rojas/1231, smith/112233, brown/999999). Ignored entirely when
# APP_ENV=production. Leave at 0 and run scripts/hash-pins.php instead.
APEX_ALLOW_DEFAULT_PINS=0
