# AeroMarkup environment
# Copy to .env and fill in. Leaving DATABASE_URL blank runs the app in
# offline-only mode (the PWA still works; nothing syncs to a server).

# PostgreSQL connection string.
# SHARED DATABASE: AeroMarkup isolates all of its tables in a dedicated
# "aeromarkup" Postgres schema (see db/schema.sql), so you can point this at
# a database already used by other apps without name collisions. Just paste
# the shared database's connection string here.
# Render:     paste your shared database's Internal Database URL
# AWS GovCloud RDS:  postgres://user:pass@<rds-endpoint>.rds.<gov-region>.amazonaws.com:5432/aeromarkup
# Azure Gov DB:      postgres://user:pass@<server>.postgres.database.usgovcloudapi.net:5432/aeromarkup?sslmode=require
DATABASE_URL=

# Listen port (Render/host sets this automatically in most cases)
PORT=8080

# Apply db/schema.sql automatically on startup
AUTO_MIGRATE=1

# ── Authentication ───────────────────────────────────────────────────
# Deployment environment. Anything other than development/dev/local/test is
# treated as production: secure cookies are required and a strong secret is
# mandatory (the app refuses to start a backend without one).
ENVIRONMENT=production

# Server signing key for session tokens. REQUIRED in production whenever a
# DATABASE_URL is configured. Must be >= 32 chars. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Never commit the real value — keep it only in your deployment's secrets.
AEROMARKUP_SECRET=

# Session lifetime in seconds (default 12h).
SESSION_TTL_SECONDS=43200

# Login brute-force throttle: max failed attempts per client IP within the
# rolling window before further logins are rejected with HTTP 429. This is an
# in-process limiter; for multi-worker/multi-replica deployments also enforce
# rate limiting at the gateway/WAF or back it with a shared store (Redis).
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300

# First-run setup: there is NO default password. On first launch against an
# empty database, the app prompts you to create the initial administrator
# (POST /api/auth/bootstrap), allowed only while no account has a password set.
