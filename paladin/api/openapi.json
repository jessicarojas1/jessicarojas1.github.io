{
  "openapi": "3.0.3",
  "info": {
    "title": "PALADIN API",
    "version": "1.0.0",
    "description": "Read-only REST API for the PALADIN (Process, Approval & Library). Authenticate with an API key via the Authorization: Bearer header or the X-API-Key header, or with an active browser session."
  },
  "servers": [
    { "url": "/api/v1" }
  ],
  "security": [
    { "bearerAuth": [] },
    { "apiKeyAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      },
      "ListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "type": "object" } },
          "count": { "type": "integer" }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid credentials",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Service health",
        "description": "Returns API service status, name, version and server time.",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "service": { "type": "string" },
                    "version": { "type": "string" },
                    "time": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "summary": "Current principal",
        "description": "Returns the authenticated user when using a session, or an api_key marker when authenticated with an API key.",
        "responses": {
          "200": {
            "description": "The current principal",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/documents": {
      "get": {
        "summary": "List documents",
        "description": "Lists controlled documents with safe fields only. Supports filtering and search.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by document status (e.g. draft, in_review, approved, published).",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by document type (doc_type, e.g. policy, procedure).",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Case-insensitive search across title and document code.",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum results to return (default 50, max 200).",
            "required": false,
            "schema": { "type": "integer", "default": 50, "maximum": 200, "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of documents",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/documents/{id}": {
      "get": {
        "summary": "Get a document",
        "description": "Returns a single document by id (safe fields plus description).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Document id.",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "The document",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/spaces": {
      "get": {
        "summary": "List spaces",
        "description": "Lists all non-archived spaces.",
        "responses": {
          "200": {
            "description": "A list of spaces",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/spaces/{id}": {
      "get": {
        "summary": "Get a space",
        "description": "Returns a single space by id.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Space id.",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "The space",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/processes": {
      "get": {
        "summary": "List processes",
        "description": "Lists processes with summary fields.",
        "responses": {
          "200": {
            "description": "A list of processes",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tasks": {
      "get": {
        "summary": "List tasks",
        "description": "Lists tasks. Supports filtering by status and assignee.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by task status (e.g. open, in_progress, done).",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "assigned_to",
            "in": "query",
            "description": "Filter by assigned user id.",
            "required": false,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of tasks",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/approvals": {
      "get": {
        "summary": "List pending approvals",
        "description": "Lists pending approval requests.",
        "responses": {
          "200": {
            "description": "A list of pending approval requests",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  }
}
