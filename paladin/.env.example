# PALADIN — environment configuration template.
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Database (PostgreSQL) ─────────────────────────────────────
# Either a single DATABASE_URL (Render/Heroku/Azure/AWS style)…
# DATABASE_URL=postgres://paladin:password@host:5432/paladin
# …or discrete vars:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paladin
DB_USER=paladin
DB_PASS=change_me_strong_password

# ── Application ───────────────────────────────────────────────
APP_NAME=PALADIN
APP_ENV=production
APP_URL=https://your-domain.gov
# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=replace_with_at_least_64_hex_chars
# Comma-separated trusted reverse-proxy IPs (for X-Real-IP / X-Forwarded-Proto)
TRUSTED_PROXY_IPS=127.0.0.1

# ── First-run admin (only used on a fresh database) ───────────
ADMIN_EMAIL=admin@your-domain.gov
ADMIN_PASSWORD=change_me_strong_admin_password

# ── Storage (cloud-agnostic abstraction) ──────────────────────
# local = mounted volume; s3 = any S3-compatible (AWS GovCloud S3, Azure via
# gateway, MinIO, Cloudflare R2). Configure further in Admin → Settings.
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=us-gov-west-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=

# ── Email (SMTP, optional) ────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=PALADIN

# ── Container port (Azure App Service sets PORT automatically) ─
PORT=80
