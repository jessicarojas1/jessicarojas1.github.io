# AEGIS GRC — Environment Configuration Template
# Copy to .env and fill in your values. Never commit .env to version control.

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aegis
DB_USER=aegis
DB_PASS=change_me_strong_password

# ── Application ───────────────────────────────────────────
APP_URL=https://your-domain.com
APP_ENV=production
# SESSION_SECRET is unused by PHP sessions but reserved for future signed cookies
SESSION_SECRET=change_me_64_random_hex_chars
# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=replace_with_64_char_hex_string

# --- Secret file mounts (Docker/K8s secrets, Vault, KMS) -------------------
# Any of JWT_SECRET, AUDIT_HMAC_KEY, APP_ENCRYPTION_KEY, DB_PASS, SMTP_PASS may
# instead be supplied via a "<NAME>_FILE" path pointing at a mounted secret, so
# the value never sits in the process environment. Example:
#   JWT_SECRET_FILE=/run/secrets/jwt_secret
# A direct value (e.g. JWT_SECRET=...) takes precedence over its _FILE.

# --- Dedicated cryptographic keys (key separation, NIST SC-12) -------------
# OPTIONAL but STRONGLY RECOMMENDED in production. When unset, AEGIS derives
# these from JWT_SECRET (backward compatible) — but then a single secret guards
# tokens, encrypted settings, AND audit integrity. Set distinct random values:
#   php -r "echo bin2hex(random_bytes(32));"
#
# Signs the tamper-evident audit hash chain. For real integrity separation,
# store this where the database role CANNOT read it (so DB compromise alone
# cannot forge the audit log). Rotating it invalidates verification of rows
# written under the old key — keep old keys for historical verification.
AUDIT_HMAC_KEY=
# Encrypts sensitive settings at rest (SMTP/S3/AI keys). Rotating JWT_SECRET no
# longer breaks decryption when this is set. Old ciphertexts still decrypt via
# the legacy JWT_SECRET-derived key (transparent migration).
APP_ENCRYPTION_KEY=

# Comma-separated list of trusted reverse proxy IPs (nginx REMOTE_ADDR)
TRUSTED_PROXY_IPS=127.0.0.1

# ── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=notifications@your-domain.com
SMTP_PASS=smtp_password
SMTP_FROM=notifications@your-domain.com
SMTP_FROM_NAME=AEGIS GRC

# ── Storage ───────────────────────────────────────────────
STORAGE_DRIVER=local
# S3 / MinIO / Cloudflare R2 (set STORAGE_DRIVER=s3 to enable)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=

# ── AI (optional) ─────────────────────────────────────────
AI_PROVIDER=claude
AI_API_KEY=

# ── Docker (for docker-compose) ───────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
