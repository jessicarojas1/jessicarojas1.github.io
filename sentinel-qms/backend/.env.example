# ─── Sentinel QMS API — Environment Configuration ───────────────────────────
# Copy to `.env` and fill in real values. NEVER commit a populated .env file.

# Runtime
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
APP_VERSION=1.0.0

# API / CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL 16)
DATABASE_URL=postgresql+psycopg://sentinel:change_me@localhost:5432/sentinel_qms
# Dedicated schema isolating Sentinel tables (safe to share a database with other
# apps). Set to "public" to use the default schema.
DB_SCHEMA=sentinel_qms

# JWT / Auth
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OIDC / SAML / CAC-PIV (federal SSO — stubbed verify path)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Bootstrap admin (seed). Leave ADMIN_AUTO_CREATE=false in production.
ADMIN_EMAIL=admin@sentinel-qms.local
ADMIN_PASSWORD=ChangeMe!Admin123
ADMIN_AUTO_CREATE=true

# Storage backend
STORAGE_BACKEND=local              # s3 | azure_blob | local
LOCAL_STORAGE_DIR=./var/uploads
S3_BUCKET=
S3_REGION=us-gov-west-1
S3_ENDPOINT_URL=                   # set to a MinIO URL (e.g. http://minio:9000) for local S3
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=sentinel-qms

# Uploads
MAX_UPLOAD_BYTES=52428800          # 50 MiB

# Outbound notifications (all optional — leave blank to disable a channel).
# Webhook URLs here act as env fallbacks; admins can override Teams/Slack and
# toggle email delivery at runtime via Settings (org_settings table).
# Microsoft Teams incoming webhook (Connector or Workflow URL)
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-teams-webhook
# Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook
# SMTP email dispatch (host/credentials are secrets — env only, not admin-editable)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@sentinel-qms.local
SMTP_USE_TLS=true

# Global API rate limiting (in-process fixed window, per credential/IP).
# Generous defaults so interactive use is never throttled; set
# RATE_LIMIT_ENABLED=false if a fronting gateway/WAF already enforces limits.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_WINDOW_SECONDS=60
# Honor X-Forwarded-For for the client IP. Enable ONLY behind a trusted
# proxy/LB (e.g. Render); off by default to prevent IP spoofing.
TRUST_PROXY_HEADERS=false

# Outbound webhooks: emit HMAC-signed lifecycle events to registered endpoints.
# Enqueue is atomic with the change; delivery is backgrounded with retries.
WEBHOOKS_ENABLED=true

# Background scheduler (SLA escalation sweep + scheduled report digest).
# Runs in-process; jobs claim their work atomically so it is safe with multiple
# web workers. Set RUN_SCHEDULER=false to disable (e.g. a dedicated worker).
RUN_SCHEDULER=true
# How often the scheduler wakes, in seconds (default 900 = 15 minutes).
SCHEDULER_INTERVAL_SECONDS=900
# Public base URL used to build deep links in notifications and the digest email.
APP_BASE_URL=https://sentinel-qms.example.com
