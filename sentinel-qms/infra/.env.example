# ─────────────────────────────────────────────────────────────────────────────
# Sentinel QMS — docker-compose environment (LOCAL DEVELOPMENT ONLY)
#
# Copy to `.env`:   cp .env.example .env
# Then edit the secrets below. NEVER commit a populated `.env`.
# These values are for localhost only and must NOT be used in any cloud env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=sentinel_qms

# ── Backend auth / API ───────────────────────────────────────────────────────
# Must be >= 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=local-dev-secret-not-for-production-min-32-chars
CORS_ORIGINS=http://localhost:8080

# ── OIDC / Federal SSO (leave blank for local) ───────────────────────────────
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── Object storage (MinIO emulates S3 locally) ───────────────────────────────
STORAGE_BACKEND=s3
S3_BUCKET=sentinel-qms-uploads
S3_REGION=us-gov-west-1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_local_only

# ── Frontend build ───────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
